{
	"name": "@mikaello/rankinglop-resultlist-generator",
	"version": "0.0.3",
	"description": "Generate old school HTML file when given an IOF v3 XML file",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"sideEffects": false,
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": {
		"rankinglop": "dist/cli.js"
	},
	"files": [
		"dist",
		"LICENSE"
	],
	"scripts": {
		"start": "node src/cli.ts",
		"prepublish": "npm run build",
		"build": "rm -rf dist && esbuild src/index.ts --bundle --format=esm --outdir=dist --external:fast-xml-parser --platform=neutral && esbuild src/cli.ts --bundle --format=esm --outdir=dist --external:fast-xml-parser --external:@picocss/pico --platform=node && tsc -p tsconfig.declarations.json",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write .",
		"test": "node --import tsx --test test/*.test.ts"
	},
	"dependencies": {
		"@picocss/pico": "2.1.1",
		"fast-xml-parser": "5.9.3"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mikaello/rankinglop-resultlist-generator.git"
	},
	"bugs": {
		"url": "https://github.com/mikaello/rankinglop-resultlist-generator/issues"
	},
	"homepage": "https://mikaello.github.io/rankinglop-resultlist-generator/",
	"keywords": [
		"iof",
		"orienteering",
		"rankingløp"
	],
	"author": "mikaello",
	"license": "GPL-3.0",
	"devDependencies": {
		"@biomejs/biome": "2.5.3",
		"@types/node": "25.9.5",
		"esbuild": "0.28.1",
		"tsx": "4.23.0",
		"typescript": "6.0.3"
	}
}
