{
	"name": "@mikaello/rankinglop-resultlist-generator",
	"version": "0.0.1",
	"description": "Generate old school HTML file when given an IOF v3 XML file",
	"type": "module",
	"main": "dist/index.js",
	"types": "dist/index.d.ts",
	"exports": {
		".": {
			"import": "./dist/index.js",
			"types": "./dist/index.d.ts"
		}
	},
	"bin": {
		"rankinglop": "dist/cli.js"
	},
	"files": [
		"dist",
		"LICENSE"
	],
	"scripts": {
		"start": "node src/cli.ts",
		"prepublish": "npm run build",
		"build": "tsup",
		"typecheck": "tsc --noEmit",
		"lint": "biome check --write .",
		"test": "node --import tsx --test test/*.test.ts"
	},
	"dependencies": {
		"@picocss/pico": "2.1.1",
		"fast-xml-parser": "5.7.0"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/mikaello/rankinglop-resultlist-generator.git"
	},
	"bugs": {
		"url": "https://github.com/mikaello/rankinglop-resultlist-generator/issues"
	},
	"homepage": "https://mikaello.github.io/rankinglop-resultlist-generator/",
	"keywords": [
		"iof",
		"orienteering",
		"rankingløp"
	],
	"author": "mikaello",
	"license": "GPL-3.0",
	"devDependencies": {
		"@biomejs/biome": "2.4.15",
		"@types/node": "25.7.0",
		"tsup": "8.5.1",
		"tsx": "4.21.0",
		"typescript": "6.0.3"
	}
}
